datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profiles      LearningProfile[]
  resources     Resource[]
  learningPaths LearningPath[]
  chatSessions  ChatSession[]
  quizResults   QuizResult[]
}

model LearningProfile {
  id        String   @id @default(cuid())
  userId    String
  version   Int      @default(1)
  dimensions Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Resource {
  id          String         @id @default(cuid())
  userId      String
  type        ResourceType
  title       String
  content     String
  metadata    Json?
  sourceAgent String
  status      ResourceStatus @default(generating)
  createdAt   DateTime       @default(now())

  user          User              @relation(fields: [userId], references: [id])
  pathNodes     PathNodeResource[]

  @@index([userId, type])
  @@index([userId, status])
}

enum ResourceType {
  document
  mindmap
  quiz
  video
  code
  reading
  ppt
}

enum ResourceStatus {
  generating
  ready
  failed
}

model LearningPath {
  id        String     @id @default(cuid())
  userId    String
  goal      String
  nodes     Json
  edges     Json
  status    PathStatus @default(active)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum PathStatus {
  active
  completed
  archived
}

model ChatSession {
  id        String      @id @default(cuid())
  userId    String
  type      SessionType
  messages  Json
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])
}

enum SessionType {
  profile_build
  tutor
  resource_request
}

model QuizResult {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  answers     Json
  score       Float
  feedback    String?
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PathNodeResource {
  id         String @id @default(cuid())
  pathId     String
  nodeId     String
  resourceId String

  resource Resource @relation(fields: [resourceId], references: [id])

  @@unique([pathId, nodeId, resourceId])
}

model StageOutline {
  stageId   String @id
  outlines  Json
  createdAt Int    @default(0)
  updatedAt Int    @default(0)
}
