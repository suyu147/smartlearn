# AI Provider Configuration
AI_PROVIDER=spark
AI_MODEL=spark-4.0-turbo

# Spark (iFlytek) Configuration
SPARK_API_KEY=your_spark_api_key_here
SPARK_API_SECRET=your_spark_api_secret_here
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1

# OpenAI Configuration (fallback)
OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek Configuration (fallback)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartlearn

# Redis
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
LLM_THINKING_DISABLED=true
