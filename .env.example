# AI Provider Configuration
AI_PROVIDER=spark
AI_MODEL=spark-4.0-turbo

# Spark (iFlytek) Configuration
SPARK_API_KEY=
SPARK_API_SECRET=your_spark_api_secret_here
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1

# OpenAI Configuration (fallback)
OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek Configuration (fallback)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Image Generation Configuration
# Provider: siliconflow | tongyi | openai | doubao
IMAGE_GEN_PROVIDER=siliconflow
IMAGE_GEN_API_KEY=your_image_gen_api_key_here
IMAGE_GEN_BASE_URL=https://api.siliconflow.cn/v1
IMAGE_GEN_MODEL=stabilityai/stable-diffusion-3-5-large

# Doubao (ByteDance) Image Generation
DOUBAO_IMAGE_API_KEY=your_doubao_image_api_key_here
DOUBAO_IMAGE_BASE_URL=https://visual.volcengineapi.com
DOUBAO_IMAGE_MODEL=doubao-seedream-3-0-t2i-250415

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartlearn

# Redis
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
LLM_THINKING_DISABLED=true
